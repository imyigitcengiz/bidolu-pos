# ─── Bidolu POS — Environment Variables ───────────────
# Copy this file as .env and edit values for your deployment

# ─── Django Backend ───────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── Docker / Dokploy ────────────────────────────────
PORT=3000

# ─── Ödeme (Abonelik) ───────────────────────────────
# mock | stripe | iyzico | auto (varsayılan: anahtar yoksa mock)
PAYMENT_PROVIDER=auto
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# iyzico (https://merchant.iyzipay.com)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
